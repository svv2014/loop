# loop.env — Local configuration (not committed to git)
# Copy this to loop.env and fill in your values.

# ─── Agent ───────────────────────────────────────────────────────────────────
# Which AI coding agent to use. Options:
#   "claude"  — Claude Code CLI (default)
#   "codex"   — OpenAI Codex CLI
#   "gemini"  — Google Gemini CLI
#   "aider"   — Aider
#   "custom"  — Your own script (set LOOP_AGENT_CMD below)
LOOP_AGENT="claude"

# Model override (optional). Defaults per agent:
#   claude: sonnet, codex: o4-mini, gemini: gemini-2.5-pro, aider: sonnet
# LOOP_AGENT_MODEL="sonnet"

# Custom agent command (only if LOOP_AGENT="custom")
# Must accept a prompt as first argument.
# LOOP_AGENT_CMD="/path/to/your/agent-wrapper.sh"

# Full orchestrator script (optional, overrides LOOP_AGENT if set)
# Must accept: <prompt> --cwd <dir>
# LOOP_ORCHESTRATOR="/path/to/orchestrator.sh"

# ─── Logs ────────────────────────────────────────────────────────────────────
LOOP_LOG_DIR="${HOME}/.loop/logs"

# ─── Dispatch ────────────────────────────────────────────────────────────────
# How events are emitted to handlers. Options:
#   "direct"  — scanner calls handlers directly via nohup (no event bus needed)
#   "event-queue" — scanner posts to an HTTP event queue
LOOP_DISPATCH_MODE="direct"

# Only needed if LOOP_DISPATCH_MODE=event-queue
# LOOP_EVENT_CLIENT="/path/to/event-queue-client.sh"

# ─── Notifications ───────────────────────────────────────────────────────────
# Optional: called on stale PRs, failures, reconciler actions
# Must accept: <message>
# Leave blank to disable. Pick one of the bundled adapters:

# Slack — requires SLACK_WEBHOOK_URL to be set; uses curl
# LOOP_NOTIFY="lib/notifiers/slack.sh"
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/T000/B000/xxxx"

# Stdout — prints timestamped lines; always succeeds (good for testing)
# LOOP_NOTIFY="lib/notifiers/stdout.sh"

# Email — pipes message to mail(1); requires LOOP_NOTIFY_EMAIL
# LOOP_NOTIFY="lib/notifiers/email.sh"
# LOOP_NOTIFY_EMAIL="you@example.com"

# ─── Environment ─────────────────────────────────────────────────────────────
# PATH additions for cron/launchd (gh, python3, agent CLI must be reachable).
# macOS (Homebrew): /opt/homebrew/bin:/usr/local/bin — Linux: /usr/local/bin or similar.
LOOP_EXTRA_PATH="/opt/homebrew/bin:/usr/local/bin"

# ─── Recovery ────────────────────────────────────────────────────────────────
# Seconds before an operational label (in-progress, in-rework, in-review) with
# no live handler process is considered stuck. Recovery strips the label and
# restores the upstream trigger so the pipeline can retry. Default: 3600 (1h).
# The stuck-label check fires when age >= HANDLER_TIMEOUT * 1.5.
# HANDLER_TIMEOUT=3600

# ─── Bounty / loop-monitor ────────────────────────────────────────────────────
# Stable identifier for this Loop instance sent with every bounty/event payload.
# Lets loop-monitor distinguish multiple Loop instances reporting to the same endpoint.
# Defaults to: <hostname>-<first8ofsha256(LOOP_ROOT)>. Set explicitly to pin the id
# across host renames or when running multiple instances on the same host.
# LOOP_ID="my-instance-id"
